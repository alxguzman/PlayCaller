# Copy this file to .env and fill in your real values.
# Never commit .env to git!

# --- Phase 4: Claude play-caller ---------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: which Claude model writes the explanations (default: haiku -
# fast + cheap, ideal for short coordinator-style blurbs).
# CLAUDE_MODEL=claude-haiku-4-5

# --- Sign-in (protects /explain from burning your Claude tokens) --
# Login is DISABLED until APP_PASSWORD is set.
APP_USERNAME=coach
APP_PASSWORD=pick-a-real-password
# Optional: signs the session tokens. If unset, a random key is generated
# at startup (everyone just re-logs-in after a server restart).
# APP_SECRET_KEY=any-long-random-string
